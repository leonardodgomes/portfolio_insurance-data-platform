	partition Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR(MIN(agg_insurance_monthly_kpis[gold_timestamp]) - 365, TODAY()),
				    "Ano", YEAR([Date]),
				    "Mês Num", MONTH([Date]),
				    "Mês Nome", FORMAT([Date], "MMMM"),
				    "Trimestre", "T" & FORMAT([Date], "Q")
				)

	annotation PBI_Id = 81de1ff4303248b5b6c852505c6a9bfa

